# Supabase — quiz completion counter (required for stats on result page)
# Use Project URL only — do NOT copy the /rest/v1/ API URL from Data API settings
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Aliyun OSS deploy (npm run deploy:china) — see docs/deployment-dual-static.md
# ALIYUN_OSS_REGION=oss-cn-hangzhou
# ALIYUN_OSS_BUCKET=your-bucket-name
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_PREFIX=football-dna
